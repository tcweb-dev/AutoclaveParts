<%- include('partials/head-open', { slides: [] }) %>

<main class="auth-main">
  <div class="auth-card">
    <h1>Login</h1>
    <%- include('partials/flash') %>
    <form method="POST" action="/login" novalidate>
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" value="<%= oldInput.email || '' %>" required maxlength="254" autocomplete="email" />
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <div class="password-wrap">
          <input type="password" id="password" name="password" required maxlength="128" autocomplete="current-password" />
          <button type="button" class="pw-toggle" id="pwToggle" aria-label="Show password">
            <svg id="pwIconShow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
            </svg>
            <svg id="pwIconHide" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
            <span class="pw-toggle-text" data-toggle-text>Show</span>
          </button>
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Login</button>
    </form>
    <p class="auth-alt">Don't have an account? <a href="/register">Create one</a></p>
  </div>
</main>
<script src="/js/passwordToggle.js" defer></script>
<%- include('partials/foot-close') %>
