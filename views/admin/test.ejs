<%- include('head') %>

<h1>Dev Test Tools</h1>
<div class="alert alert-info">
  These tools are only available in <strong>development</strong> mode.
</div>

<section class="admin-section">
  <h2>Seed Test Data</h2>
  <p>
    Inserts test customers, carousel slides, grid ads, and sidebar items into
    the database.
  </p>
  <form method="POST" action="/secure-admin/test/seed">
    <button
      type="submit"
      class="btn btn-primary"
      onclick="
        return confirm(
          'This will insert seed data. Existing records are kept.',
        );
      "
    >
      Run Seed
    </button>
  </form>
</section>

