<%- include('head') %>

<h1>Send Bulk Email to All Customers</h1>

<section class="admin-section">
  <form method="POST" action="/secure-admin/email" novalidate>
    <div class="form-group">
      <label for="subject">Subject <span class="required">*</span></label>
      <input
        type="text"
        id="subject"
        name="subject"
        required
        maxlength="200"
        value="<%= oldInput.subject || '' %>"
      />
    </div>
    <div class="form-group">
      <label for="bodyText"
        >Message (plain text) <span class="required">*</span></label
      >
      <textarea
        id="bodyText"
        name="bodyText"
        rows="8"
        required
        maxlength="10000"
      >
<%= oldInput.bodyText || '' %></textarea
      >
    </div>
    <div class="form-group">
      <label for="bodyHtml"
        >Message (HTML – optional, overrides plain text in HTML-capable
        clients)</label
      >
      <textarea id="bodyHtml" name="bodyHtml" rows="8" maxlength="50000">
<%= oldInput.bodyHtml || '' %></textarea
      >
    </div>
    <p class="form-note">
      This will send an individual email to every active customer in the
      database. Each recipient's address is kept private.
    </p>
    <button
      type="submit"
      class="btn btn-primary"
      onclick="return confirm('Send this email to ALL customers?');"
    >
      Send Bulk Email
    </button>
  </form>
</section>

<%- include('foot') %>
