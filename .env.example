# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/PlaceholderParts

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=noname@nothing.com
ADMIN_PASSWORD_HASH=   # run: node -e "const b=require('bcrypt');b.hash('yourpassword',12).then(console.log)"

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=yourpassword
EMAIL_FROM="PlaceholderParts <no-reply@placeholderparts.com>"
NOTIFY_EMAIL=noname@nothing.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Prices (in cents) ─────────────────────────────────────────────────────────
PRICE_CAROUSEL=10000
PRICE_GRID=5000
